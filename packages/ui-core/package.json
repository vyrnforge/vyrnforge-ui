{
  "name": "@vyrnforge/ui-core",
  "version": "0.1.0-alpha.1",
  "description": "Native-first VyrnForge UI design tokens, themes, density, utilities, and shared CSS foundations.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/index.css",
    "./index.css": "./dist/index.css",
    "./styles/index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/index.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vyrnforge/vyrnforge-ui.git",
    "directory": "packages/ui-core"
  },
  "homepage": "https://github.com/vyrnforge/vyrnforge-ui#readme",
  "bugs": {
    "url": "https://github.com/vyrnforge/vyrnforge-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12 <25",
    "npm": ">=11.16 <12"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && node ../../scripts/prepare-package-declarations.mjs .",
    "lint": "eslint . --config ../../eslint.config.mjs",
    "lint:fix": "eslint . --config ../../eslint.config.mjs --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "tsup": "latest",
    "typescript": "7.0.2",
    "vitest": "latest"
  }
}
