{
  "name": "@vyrnforge/ui-data-grid",
  "version": "0.1.0-alpha.1",
  "description": "Native-first enterprise data-management grid for VyrnForge UI.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/index.css",
    "./index.css": "./dist/index.css",
    "./styles/index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/index.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vyrnforge/vyrnforge-ui.git",
    "directory": "packages/ui-data-grid"
  },
  "homepage": "https://github.com/vyrnforge/vyrnforge-ui#readme",
  "bugs": {
    "url": "https://github.com/vyrnforge/vyrnforge-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12 <25",
    "npm": ">=10 <12"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && node ../../scripts/prepare-package-declarations.mjs .",
    "pretypecheck": "npm run build --workspace @vyrnforge/ui-core && npm run build --workspace @vyrnforge/ui-components",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "dependencies": {
    "@vyrnforge/ui-components": "0.1.0-alpha.1",
    "@vyrnforge/ui-core": "0.1.0-alpha.1"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tsup": "latest",
    "typescript": "7.0.2",
    "vitest": "latest"
  }
}
