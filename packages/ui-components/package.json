{
  "name": "@vyrnforge/ui-components",
  "version": "0.1.0-alpha.1",
  "description": "Native-first VyrnForge UI React primitives and application components.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/index.css",
    "./index.css": "./dist/index.css",
    "./styles/index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/index.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vyrnforge/vyrnforge-ui.git",
    "directory": "packages/ui-components"
  },
  "homepage": "https://github.com/vyrnforge/vyrnforge-ui#readme",
  "bugs": {
    "url": "https://github.com/vyrnforge/vyrnforge-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12 <25",
    "npm": ">=11.16 <12"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && node ../../scripts/prepare-package-declarations.mjs .",
    "lint": "eslint . --config ../../eslint.config.mjs",
    "lint:fix": "eslint . --config ../../eslint.config.mjs --fix",
    "pretypecheck": "npm run build --workspace @vyrnforge/ui-core",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@vyrnforge/ui-core": "0.1.0-alpha.1"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "react": "latest",
    "react-dom": "latest",
    "tsup": "latest",
    "typescript": "7.0.2",
    "vitest": "latest"
  }
}
