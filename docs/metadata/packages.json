{
  "schemaVersion": 1,
  "sourceOfTruth": "docs/README.md",
  "packages": [
    {
      "name": "@vyrnforge/ui-core",
      "purpose": "Shared VyrnForge design foundation for semantic tokens, themes, density, typography, motion, layers, utilities, and theme helpers.",
      "owns": [
        "primitive tokens",
        "semantic tokens",
        "themes",
        "density",
        "typography roles",
        "motion and reduced-motion contract",
        "layering model",
        "utility classes",
        "theme helper contracts"
      ],
      "doesNotOwn": [
        "React components",
        "data grid behavior",
        "app state",
        "backend fetching",
        "business workflows"
      ],
      "cssImport": "@vyrnforge/ui-core/styles/index.css",
      "apiDoc": "docs/api/ui-core-api.md",
      "dependsOn": [],
      "mustNotDependOn": [
        "@vyrnforge/ui-components",
        "@vyrnforge/ui-data-grid",
        "Redux",
        "TanStack",
        "MUI",
        "Radix",
        "Tailwind"
      ],
      "status": "current",
      "publicEntryPoints": [
        "@vyrnforge/ui-core",
        "@vyrnforge/ui-core/styles/index.css",
        "@vyrnforge/ui-core/style.css",
        "@vyrnforge/ui-core/index.css"
      ],
      "notes": "Lowest-level dependency-free runtime package. Canonical semantic token metadata lives in docs/metadata/design-tokens.json."
    },
    {
      "name": "@vyrnforge/ui-components",
      "purpose": "Reusable native-first React primitives and application components.",
      "owns": [
        "actions",
        "typography",
        "forms",
        "data management",
        "feedback",
        "layout",
        "overlays",
        "shared vf-* classes"
      ],
      "doesNotOwn": [
        "data grid algorithms",
        "grid row models",
        "backend data",
        "global store",
        "tenant/auth/permissions"
      ],
      "cssImport": "@vyrnforge/ui-components/styles/index.css",
      "apiDoc": "docs/api/ui-components-api.md",
      "dependsOn": ["@vyrnforge/ui-core"],
      "mustNotDependOn": [
        "@vyrnforge/ui-data-grid",
        "Redux",
        "TanStack",
        "MUI",
        "Radix",
        "Tailwind"
      ],
      "status": "current",
      "publicEntryPoints": [
        "@vyrnforge/ui-components",
        "@vyrnforge/ui-components/styles/index.css",
        "@vyrnforge/ui-components/style.css",
        "@vyrnforge/ui-components/index.css"
      ],
      "notes": "Use for reusable UI outside specialized grid behavior."
    },
    {
      "name": "@vyrnforge/ui-data-grid",
      "purpose": "Specialized enterprise data-management grid and grid contracts.",
      "owns": [
        "UniversalDataGrid",
        "grid-specific udg-* styles",
        "grid state contracts",
        "grid core helpers",
        "persistence/server/export adapters"
      ],
      "doesNotOwn": [
        "API calls",
        "export file generation by default",
        "report engine",
        "global store",
        "backend business workflows"
      ],
      "cssImport": "@vyrnforge/ui-data-grid/styles/index.css",
      "apiDoc": "docs/api/ui-data-grid-api.md",
      "dependsOn": ["@vyrnforge/ui-core", "@vyrnforge/ui-components"],
      "mustNotDependOn": ["Redux", "TanStack", "MUI", "Radix", "Tailwind"],
      "status": "current",
      "publicEntryPoints": [
        "@vyrnforge/ui-data-grid",
        "@vyrnforge/ui-data-grid/styles/index.css",
        "@vyrnforge/ui-data-grid/style.css",
        "@vyrnforge/ui-data-grid/index.css"
      ],
      "notes": "Apps own rows, fetching, permissions, business actions, and file generation."
    }
  ],
  "dependencyRules": [
    "ui-core depends on no VyrnForge package",
    "ui-components may depend on ui-core",
    "ui-data-grid may depend on ui-core and ui-components",
    "ui-core must never depend on ui-components or ui-data-grid",
    "ui-components must never depend on ui-data-grid"
  ]
}
