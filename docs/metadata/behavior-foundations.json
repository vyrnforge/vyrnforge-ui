{
  "schemaVersion": 1,
  "program": {
    "sprint": "S5",
    "batch": "MF-5001-MF-5010",
    "status": "implemented",
    "gate": "GMF2",
    "gateStatus": "in-progress",
    "package": "@vyrnforge/ui-behaviors"
  },
  "tasks": [
    {
      "id": "MF-5001",
      "name": "Controllable state primitives",
      "status": "done"
    },
    {
      "id": "MF-5002",
      "name": "Collection and active-item primitives",
      "status": "done"
    },
    {
      "id": "MF-5003",
      "name": "Selection models",
      "status": "done"
    },
    {
      "id": "MF-5004",
      "name": "Canonical controller event model",
      "status": "done"
    },
    {
      "id": "MF-5005",
      "name": "Simple action and toggle behaviors",
      "status": "done"
    },
    {
      "id": "MF-5006",
      "name": "Simple form-control behaviors",
      "status": "done"
    },
    {
      "id": "MF-5007",
      "name": "Tabs and composite navigation behavior",
      "status": "done"
    },
    {
      "id": "MF-5008",
      "name": "Autocomplete behavior",
      "status": "done"
    },
    {
      "id": "MF-5009",
      "name": "MultiSelect behavior",
      "status": "done"
    },
    {
      "id": "MF-5010",
      "name": "Transfer List behavior",
      "status": "done"
    }
  ],
  "contracts": {
    "controllableState": {
      "factory": "createControllableState",
      "controlledDetection": "property-presence",
      "committedSnapshotMethods": ["getSnapshot", "subscribe", "syncValue"],
      "changeRequestMethods": ["setValue", "reset"],
      "event": "value-change"
    },
    "collection": {
      "factory": "createCollectionController",
      "keyTypes": ["string", "number"],
      "navigation": ["first", "last", "next", "previous"],
      "rules": [
        "deterministic-order",
        "disabled-items-skipped",
        "loop-or-clamp",
        "active-item-reconciled-after-mutation"
      ],
      "events": ["collection-change", "active-change"]
    },
    "selection": {
      "factory": "createSelectionController",
      "modes": ["single", "multiple"],
      "operations": [
        "select",
        "deselect",
        "toggle",
        "range",
        "replace",
        "clear"
      ],
      "rules": [
        "unique-keys",
        "disabled-keys-rejected",
        "ordered-range-source",
        "controlled-proposals-require-sync"
      ],
      "event": "selection-change"
    },
    "events": {
      "factory": "createBehaviorEvent",
      "channelFactory": "createBehaviorEventChannel",
      "snapshotChannelFactory": "createBehaviorSnapshotChannel",
      "reasons": [
        "user",
        "programmatic",
        "keyboard",
        "pointer",
        "selection",
        "collection-change",
        "clear",
        "reset",
        "restore"
      ],
      "rules": [
        "immutable-event-record",
        "stable-listener-snapshot",
        "idempotent-unsubscribe"
      ]
    },
    "actionToggle": {
      "factories": [
        "resolveActionState",
        "createToggleController",
        "createToggleGroupController"
      ],
      "reactAdapters": [
        "Button",
        "ToggleButton",
        "ToggleButtonGroup",
        "SegmentedControl"
      ],
      "rules": [
        "loading-disables-action",
        "controlled-toggle-proposals",
        "single-and-multiple-toggle-groups"
      ]
    },
    "choice": {
      "factory": "createChoiceController",
      "reactAdapters": ["SegmentedControl", "RadioGroup"],
      "rules": [
        "disabled-choice-rejected",
        "deterministic-order",
        "active-navigation-skips-disabled"
      ]
    },
    "numeric": {
      "factory": "createNumericValueController",
      "normalizer": "normalizeNumericValue",
      "reactAdapters": ["Slider", "Rating"],
      "rules": [
        "clamp-range",
        "finite-values",
        "optional-step-alignment",
        "controlled-proposals-require-sync"
      ]
    },
    "tabs": {
      "factory": "createTabsController",
      "reactAdapter": "Tabs",
      "rules": [
        "disabled-tabs-skipped",
        "home-end-navigation",
        "automatic-activation",
        "dom-focus-owned-by-renderer"
      ]
    },
    "nativeToggleInputs": {
      "resolver": "resolveToggleInputState",
      "reactAdapters": ["Checkbox", "Switch"],
      "rules": [
        "native-input-state-preserved",
        "form-reset-remains-native",
        "disabled-and-readonly-interactivity"
      ]
    },
    "autocomplete": {
      "factory": "createAutocompleteController",
      "reactAdapter": "Autocomplete",
      "rules": [
        "controlled-value-input-and-open-proposals",
        "filter-and-keyword-matching",
        "disabled-options-skipped",
        "selection-restores-label",
        "dom-focus-owned-by-renderer"
      ]
    },
    "multiSelect": {
      "factory": "createMultiSelectController",
      "reactAdapter": "MultiSelect",
      "rules": [
        "controlled-selection-proposals",
        "query-filtering",
        "disabled-options-rejected",
        "looping-active-navigation",
        "dom-focus-owned-by-renderer"
      ]
    },
    "transferList": {
      "factory": "createTransferListController",
      "reactAdapter": "TransferList",
      "rules": [
        "ordered-source-target-partition",
        "visible-selection",
        "disabled-items-not-moved",
        "controlled-target-proposals",
        "independent-panel-filtering"
      ]
    }
  },
  "boundaries": {
    "allowedPackageDependencies": ["@vyrnforge/ui-core"],
    "forbiddenRuntimes": ["react", "react-dom", "vue", "@angular/*"],
    "forbiddenDomIdentifiers": [
      "HTMLElement",
      "ElementInternals",
      "CustomEvent",
      "document",
      "window",
      "customElements"
    ],
    "ownsCss": false
  },
  "requiredCommands": [
    "npm run test:behavior-foundations",
    "npm run verify:behavior-foundations",
    "npm run test:coverage --workspace @vyrnforge/ui-behaviors",
    "npm run verify:package-boundaries",
    "npm run test:coverage --workspace @vyrnforge/ui-components",
    "npm run typecheck --workspace @vyrnforge/ui-components",
    "npm run quality"
  ],
  "remainingGmf2Tasks": [
    "MF-5011",
    "MF-5012",
    "MF-5013",
    "MF-5014",
    "MF-5015",
    "MF-5016"
  ]
}
